From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: szk <nbccindy8@gmail.com>
Date: Tue, 26 May 2026 15:46:00 +0800
Subject: [PATCH] Fix SiLRI actor std device for CPU actor

---
 src/lerobot/policies/silri/modeling_silri.py | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/src/lerobot/policies/silri/modeling_silri.py b/src/lerobot/policies/silri/modeling_silri.py
index 341220a..36ae136 100644
--- a/src/lerobot/policies/silri/modeling_silri.py
+++ b/src/lerobot/policies/silri/modeling_silri.py
@@ -532,7 +532,7 @@ class SiLRIPolicy(
             network=MLP(input_dim=self.encoder_actor.output_dim, **asdict(self.config.actor_network_kwargs)),
             action_dim=continuous_action_dim,
             encoder_is_shared=self.shared_encoder,
-            fixed_std=torch.tensor([5e-2]).to("cuda:0"),
+            fixed_std=torch.tensor([5e-2], device=self.config.device),
             **asdict(self.config.policy_kwargs),
         )
         if self.config.num_discrete_actions is not None:
@@ -543,7 +543,7 @@ class SiLRIPolicy(
             network=MLP(input_dim=self.encoder_actor.output_dim, **asdict(self.config.actor_network_kwargs)),
             action_dim=continuous_action_dim,
             encoder_is_shared=self.shared_encoder,
-            fixed_std=torch.tensor([5e-2]).to("cuda:0"),
+            fixed_std=torch.tensor([5e-2], device=self.config.device),
             **asdict(self.config.policy_kwargs),
         )
         self.actor_target.load_state_dict(self.actor.state_dict())
